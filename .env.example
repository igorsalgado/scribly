# HuggingFace token para baixar modelos pyannote (diarização de speakers)
# Obtenha em: https://huggingface.co/settings/tokens
# Aceite os termos em:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_...

# Modelo Whisper: tiny | base | small | medium | large-v3
# small (~500MB) é um bom balanço para português
WHISPER_MODEL=medium

# Modelo Ollama para extração de regras de negócio
# Opções: mistral | llama3.2:3b | phi4 | gemma3
OLLAMA_MODEL=mistral

# URL do Ollama (padrão via Docker)
OLLAMA_URL=http://localhost:11434
