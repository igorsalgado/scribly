# Required to bake Pyannote models into the Docker image.
# After build, runtime can reuse the cached models.
HF_TOKEN=hf_...

# Models
# Opções: mistral | llama3.2:3b | phi4 | gemma3
# Modelo Whisper embutido na imagem: tiny | base | small | medium | large-v3
WHISPER_MODEL=medium
OLLAMA_MODEL=mistral

# Local app paths, all centralized in settings.py
OUTPUT_DIR=output
DB_PATH=data/scribly.db

# Live transcription
AUDIO_SAMPLE_RATE=16000
LIVE_TRANSCRIPTION_CHUNK_SECONDS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PROGRESS_CHANNEL=scribly:progress
